# Copy this file to .env and fill in your values

# ── Database (NeonDB PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://cybershieldindia.com"

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get keys from: razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXX"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXX"
